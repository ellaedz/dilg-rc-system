{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.18.1",
    "expo": "~54.0.36",
    "expo-asset": "~12.0.13",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.7",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/jest": "^29.5.14",
    "@types/jpeg-js": "^0.3.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "start:lan": "node ./scripts/start-lan.js",
    "start:lan:clear": "node ./scripts/start-lan.js --clear",
    "start:tunnel": "node ./scripts/start-tunnel.js",
    "start:tunnel:clear": "node ./scripts/start-tunnel.js --clear",
    "start:usb": "node ./scripts/start-usb.js",
    "start:usb:clear": "node ./scripts/start-usb.js --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "lint": "eslint .",
    "test": "jest --runInBand"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-fast-tflite"
        ]
      }
    }
  },
  "private": true
}
